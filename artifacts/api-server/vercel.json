{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": ".",
  "functions": {
    "artifacts/api-server/api/index.mjs": {
      "includeFiles": "artifacts/api-server/src/**","
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/artifacts/api-server/api/index.mjs"
    }
  ]
}
